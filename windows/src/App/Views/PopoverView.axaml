<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:LLMUsageWidget.App.ViewModels"
             xmlns:views="using:LLMUsageWidget.App.Views"
             x:Class="LLMUsageWidget.App.Views.PopoverView"
             x:DataType="vm:PopoverViewModel"
             Width="340">
  <Border Background="#0B1120" CornerRadius="14" Padding="14">
    <StackPanel Spacing="10">

      <!-- Header -->
      <Grid ColumnDefinitions="Auto,*,Auto">
        <StackPanel Orientation="Horizontal" Spacing="9" VerticalAlignment="Center">
          <views:ClaudeMascot VerticalAlignment="Center"/>
          <TextBlock Text="LLM Usage" FontSize="15" FontWeight="SemiBold" Foreground="#F8FAFC" VerticalAlignment="Center"/>
        </StackPanel>
        <TextBlock Grid.Column="2" Text="{Binding Updated}" FontSize="12" Foreground="#64748B" VerticalAlignment="Center"/>
      </Grid>

      <!-- Provider cards -->
      <ItemsControl ItemsSource="{Binding Cards}">
        <ItemsControl.ItemsPanel>
          <ItemsPanelTemplate><StackPanel Spacing="10"/></ItemsPanelTemplate>
        </ItemsControl.ItemsPanel>
        <ItemsControl.ItemTemplate>
          <DataTemplate x:DataType="vm:ProviderCardViewModel">
            <Border Background="#131C30" BorderBrush="#1E293B" BorderThickness="1" CornerRadius="12" Padding="14">
              <StackPanel Spacing="12">

                <!-- Card header -->
                <Grid ColumnDefinitions="Auto,Auto,*,Auto" VerticalAlignment="Center">
                  <Path Data="{Binding Logo}" Fill="{Binding Accent}" Stretch="Uniform"
                        Width="16" Height="16" VerticalAlignment="Center"/>
                  <TextBlock Grid.Column="1" Text="{Binding Name}" Margin="9,0,0,0"
                             FontSize="15" FontWeight="SemiBold" Foreground="#F8FAFC" VerticalAlignment="Center"/>
                  <Border Grid.Column="2" IsVisible="{Binding HasPlan}" Margin="9,0,0,0"
                          HorizontalAlignment="Left" VerticalAlignment="Center"
                          Background="#22304A" CornerRadius="5" Padding="7,2">
                    <TextBlock Text="{Binding Plan}" FontSize="11" FontWeight="SemiBold" Foreground="#CBD5E1"/>
                  </Border>
                  <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
                    <Ellipse Width="7" Height="7" Fill="{Binding StatusBrush}"/>
                    <TextBlock Text="{Binding Status}" FontSize="12" Foreground="#94A3B8"/>
                  </StackPanel>
                </Grid>

                <!-- Windows -->
                <ItemsControl ItemsSource="{Binding Windows}">
                  <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate><StackPanel Spacing="12"/></ItemsPanelTemplate>
                  </ItemsControl.ItemsPanel>
                  <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:WindowRowViewModel">
                      <StackPanel Spacing="6">
                        <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Bottom">
                          <TextBlock Text="{Binding Title}" FontSize="13" Foreground="#94A3B8" VerticalAlignment="Bottom"/>
                          <TextBlock Grid.Column="1" Text="{Binding PercentText}" FontSize="24" FontWeight="Bold"
                                     Foreground="{Binding PercentBrush}"/>
                        </Grid>
                        <Border Background="{Binding Track}" Height="8" CornerRadius="4" Width="282"
                                HorizontalAlignment="Left" IsVisible="{Binding !Unlimited}">
                          <Border Background="{Binding PercentBrush}" CornerRadius="4" HorizontalAlignment="Left"
                                  Width="{Binding Fraction, Converter={StaticResource FracW}, ConverterParameter=282}"/>
                        </Border>
                        <TextBlock Text="{Binding ResetText}" FontSize="12" Foreground="#64748B"/>
                      </StackPanel>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>

              </StackPanel>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>

      <!-- Footer -->
      <Grid ColumnDefinitions="Auto,*,Auto" Margin="2,2,2,0">
        <TextBlock Text="Settings" FontSize="13" Foreground="#94A3B8"/>
        <TextBlock Grid.Column="2" Text="Quit" FontSize="13" Foreground="#94A3B8"/>
      </Grid>

    </StackPanel>
  </Border>
</UserControl>
